#!/usr/bin/env bash
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

echo "==> verify-release: start"

if command -v uv >/dev/null 2>&1; then
  uv run python -m pytest --cov=envrctl --cov-report=term-missing --cov-fail-under=90
else
  python -m pytest --cov=envrctl --cov-report=term-missing --cov-fail-under=90
fi

echo "==> verify-release: OK"
